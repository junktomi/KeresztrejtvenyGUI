<Window x:Class="KeresztrejtvenyGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KeresztrejtvenyGUI"
        mc:Ignorable="d"
        Title="Keresztrejtvény készítő" Height="600" Width="800">
    <StackPanel Margin="10">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Keresztrejtvény mérete (sor x oszlop): " VerticalAlignment="Center"/>

            <ComboBox x:Name="cbSor" Width="60" Margin="5"/>
            <ComboBox x:Name="cbOszlop" Width="60" Margin="5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Keresztrejtvény létrehozása" Margin="5" Click="Button_Click"/>

            <Button Content="Keresztrejtvény mentése" Margin="5"/>

            <ComboBox x:Name="cbIndex" Width="60" Margin="5"/>
        </StackPanel>

        <ScrollViewer>
            <UniformGrid x:Name="gridRacs"/>
        </ScrollViewer>

    </StackPanel>
</Window>
